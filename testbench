`timescale 1ns / 1ps

module alu_top_tb;

reg [7:0] a,b;
reg cin;
reg [2:0] sel;
wire [7:0] out;
wire cout,zero;

integer pass_count = 0;
integer fail_count = 0;

alu_top DUT(
    .a(a),
    .b(b),
    .cin(cin),
    .sel(sel),
    .out(out),
    .cout(cout),
    .zero(zero)
);

task chk;
    input [7:0]   a_in, b_in;
    input         cin_in;
    input [2:0]   sel_in;
    input [7:0]   exp_out;
    input [127:0] op_name;
    begin
        a = a_in; b = b_in; cin = cin_in; sel = sel_in;
        #10;
        if (out === exp_out) begin
            pass_count = pass_count + 1;
            $display("PASS %-4s A=%h B=%h Cin=%b -> OUT=%h (expected %h) COUT=%b ZERO=%b",
                       op_name, a, b, cin, out, exp_out, cout, zero);
        end else begin
            fail_count = fail_count + 1;
            $display("FAIL %-4s A=%h B=%h Cin=%b -> OUT=%h (expected %h) COUT=%b ZERO=%b",
                       op_name, a, b, cin, out, exp_out, cout, zero);
        end
    end
endtask

initial begin
    $display("Op   | Inputs             | Outputs");
    $display("--------------------------------------------------------------------");

    // ---------------- ADD (sel=000) ----------------
    chk(8'h0F, 8'h0F, 1'b0, 3'b000, 8'h1E, "ADD");
    chk(8'hFF, 8'h01, 1'b0, 3'b000, 8'h00, "ADD");
    chk(8'h00, 8'h00, 1'b0, 3'b000, 8'h00, "ADD");
    chk(8'h7F, 8'h01, 1'b0, 3'b000, 8'h80, "ADD");
    chk(8'hFF, 8'hFF, 1'b1, 3'b000, 8'hFF, "ADD");
    chk(8'h01, 8'h01, 1'b1, 3'b000, 8'h03, "ADD");
    chk(8'h80, 8'h80, 1'b0, 3'b000, 8'h00, "ADD");
    chk(8'h55, 8'hAA, 1'b0, 3'b000, 8'hFF, "ADD");
    chk(8'h10, 8'h20, 1'b0, 3'b000, 8'h30, "ADD");
    chk(8'h00, 8'h00, 1'b1, 3'b000, 8'h01, "ADD");

    // ---------------- SUB (sel=001) ----------------
    chk(8'h0F, 8'h0F, 1'b0, 3'b001, 8'h00, "SUB");
    chk(8'hFF, 8'h01, 1'b0, 3'b001, 8'hFE, "SUB");
    chk(8'h01, 8'hFF, 1'b0, 3'b001, 8'h02, "SUB");
    chk(8'h10, 8'h0F, 1'b1, 3'b001, 8'h00, "SUB");
    chk(8'h00, 8'h00, 1'b1, 3'b001, 8'hFF, "SUB");
    chk(8'h80, 8'h01, 1'b0, 3'b001, 8'h7F, "SUB");
    chk(8'hFF, 8'hFF, 1'b0, 3'b001, 8'h00, "SUB");
    chk(8'h05, 8'h0A, 1'b0, 3'b001, 8'hFB, "SUB");
    chk(8'hAA, 8'h55, 1'b0, 3'b001, 8'h55, "SUB");
    chk(8'h00, 8'h01, 1'b0, 3'b001, 8'hFF, "SUB");

    // ---------------- AND (sel=010) ----------------
    chk(8'hFF, 8'hFF, 1'b0, 3'b010, 8'hFF, "AND");
    chk(8'hAA, 8'h0F, 1'b0, 3'b010, 8'h0A, "AND");
    chk(8'h00, 8'hFF, 1'b0, 3'b010, 8'h00, "AND");
    chk(8'h55, 8'hAA, 1'b0, 3'b010, 8'h00, "AND");
    chk(8'hF0, 8'h0F, 1'b0, 3'b010, 8'h00, "AND");
    chk(8'hFF, 8'h00, 1'b0, 3'b010, 8'h00, "AND");
    chk(8'h3C, 8'hFF, 1'b0, 3'b010, 8'h3C, "AND");
    chk(8'h81, 8'h81, 1'b0, 3'b010, 8'h81, "AND");
    chk(8'h0F, 8'h0F, 1'b0, 3'b010, 8'h0F, "AND");
    chk(8'hE1, 8'h1E, 1'b0, 3'b010, 8'h00, "AND");

    // ---------------- OR (sel=011) ----------------
    chk(8'hAA, 8'h55, 1'b0, 3'b011, 8'hFF, "OR");
