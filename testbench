    chk(8'h12, 8'h21, 1'b0, 3'b011, 8'h33, "OR");

    // ---------------- XOR (sel=100) ----------------
    chk(8'hFF, 8'hFF, 1'b0, 3'b100, 8'h00, "XOR");
    chk(8'hAA, 8'h55, 1'b0, 3'b100, 8'hFF, "XOR");
    chk(8'h0F, 8'h0F, 1'b0, 3'b100, 8'h00, "XOR");
    chk(8'hFF, 8'h00, 1'b0, 3'b100, 8'hFF, "XOR");
    chk(8'h12, 8'h34, 1'b0, 3'b100, 8'h26, "XOR");
    chk(8'h00, 8'h00, 1'b0, 3'b100, 8'h00, "XOR");
    chk(8'h80, 8'h80, 1'b0, 3'b100, 8'h00, "XOR");
    chk(8'h3C, 8'hC3, 1'b0, 3'b100, 8'hFF, "XOR");
    chk(8'h11, 8'h22, 1'b0, 3'b100, 8'h33, "XOR");
    chk(8'hAB, 8'hCD, 1'b0, 3'b100, 8'h66, "XOR");

    // ---------------- NOT (sel=101, B ignored) ----------------
    chk(8'h00, 8'h00, 1'b0, 3'b101, 8'hFF, "NOT");
    chk(8'hFF, 8'h00, 1'b0, 3'b101, 8'h00, "NOT");
    chk(8'h0F, 8'h00, 1'b0, 3'b101, 8'hF0, "NOT");
    chk(8'hAA, 8'h00, 1'b0, 3'b101, 8'h55, "NOT");
    chk(8'h55, 8'h00, 1'b0, 3'b101, 8'hAA, "NOT");
    chk(8'h80, 8'h00, 1'b0, 3'b101, 8'h7F, "NOT");
    chk(8'h7F, 8'h00, 1'b0, 3'b101, 8'h80, "NOT");
    chk(8'h01, 8'h00, 1'b0, 3'b101, 8'hFE, "NOT");
