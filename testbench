    chk(8'h80, 8'h00, 1'b0, 3'b110, 8'h00, "SHL");
    chk(8'h7F, 8'h00, 1'b0, 3'b110, 8'hFE, "SHL");
    chk(8'hFF, 8'h00, 1'b0, 3'b110, 8'hFE, "SHL");
    chk(8'h55, 8'h00, 1'b0, 3'b110, 8'hAA, "SHL");
    chk(8'hAA, 8'h00, 1'b0, 3'b110, 8'h54, "SHL");
    chk(8'h0F, 8'h00, 1'b0, 3'b110, 8'h1E, "SHL");

    // ---------------- SHR (sel=111) ----------------
    chk(8'h81, 8'h00, 1'b0, 3'b111, 8'h40, "SHR");
    chk(8'h00, 8'h00, 1'b0, 3'b111, 8'h00, "SHR");
    chk(8'h02, 8'h00, 1'b0, 3'b111, 8'h01, "SHR");
    chk(8'h80, 8'h00, 1'b0, 3'b111, 8'h40, "SHR");
    chk(8'h01, 8'h00, 1'b0, 3'b111, 8'h00, "SHR");
    chk(8'hFF, 8'h00, 1'b0, 3'b111, 8'h7F, "SHR");
    chk(8'hFE, 8'h00, 1'b0, 3'b111, 8'h7F, "SHR");
    chk(8'hAA, 8'h00, 1'b0, 3'b111, 8'h55, "SHR");
    chk(8'h55, 8'h00, 1'b0, 3'b111, 8'h2A, "SHR");
    chk(8'h0F, 8'h00, 1'b0, 3'b111, 8'h07, "SHR");

    $display("--------------------------------------------------------------------");
    $display("TOTAL: %0d passed, %0d failed (out of %0d test vectors)",
               pass_count, fail_count, pass_count+fail_count);
    $finish;
end

initial begin
    $dumpfile("alu_top_tb.vcd");
    $dumpvars(0, alu_top_tb);
end

endmodule
